@@ -107,6 +107,20 @@ class AudioProcessor:
             if current_segment:
                 merged_ads.append(current_segment)
 
+            # Expand ad boundaries to avoid leaving partial ad audio.
+            # LLM-detected boundaries often land mid-word or mid-sentence;
+            # padding ensures the entire ad transition is captured.
+            AD_START_PAD = float(os.environ.get('AD_START_PAD', '1.5'))
+            AD_END_PAD = float(os.environ.get('AD_END_PAD', '2.0'))
+            # End-of-file ads get extra padding because the LLM tends to truncate
+            # outros early when Whisper drops the trailing music/jingle.
+            AD_END_PAD_TAIL = float(os.environ.get('AD_END_PAD_TAIL', '5.0'))
+            tail_threshold = 5.0  # treat as tail-of-file when within this many seconds
+            for ad in merged_ads:
+                ad['start'] = max(0, ad['start'] - AD_START_PAD)
+                end_pad = AD_END_PAD_TAIL if (total_duration - ad['end']) <= tail_threshold else AD_END_PAD
+                ad['end'] = min(total_duration, ad['end'] + end_pad)
+
             # Filter out short ad detections (< 10 seconds) - likely false positives
             MIN_AD_DURATION_FOR_REMOVAL = 10.0  # seconds
             ads = []
