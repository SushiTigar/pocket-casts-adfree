@@ -230,3 +259,63 @@ def detect_postroll(
         'reason': f'Post-roll ad ({match_count} ad indicators after sign-off)',
         'detection_stage': 'heuristic_postroll',
     }
+
+
+# Tail-gap thresholds. When Whisper produces no segments for a long stretch at
+# the end of the file, treat that as untranscribed audio and flag it as a
+# post-roll candidate (musical outros, silent ads, DAI-injected outros).
+TAIL_GAP_MIN_SECONDS = float(__import__('os').environ.get('TAIL_GAP_MIN_SECONDS', '60'))
+TAIL_GAP_OVERLAP_BACK = 5.0  # eat into the last transcribed segment slightly to swallow lead-ins
+
+
+def detect_tail_gap(
+    segments: List[Dict],
+    existing_ads: List[Dict],
+    episode_duration: float = 0,
+) -> Optional[Dict]:
+    """Flag the untranscribed audio tail as a post-roll candidate.
+
+    Whisper sometimes drops the trailing N minutes of an episode when those
+    minutes are music, jingle, or sponsor audio with no clear speech. The LLM
+    can't see what isn't transcribed, so it either places the post-roll way too
+    late or misses it entirely. This detector emits a synthetic ad covering the
+    gap so the audio processor can cut it.
+
+    Args:
+        segments: Transcript segments with 'start', 'end', 'text' keys
+        existing_ads: Already-detected ads to avoid duplicates
+        episode_duration: Total episode duration (from audio file, not transcript)
+
+    Returns:
+        Ad marker dict if tail gap detected, None otherwise
+    """
+    if not segments or episode_duration <= 0:
+        return None
+
+    last_segment_end = segments[-1].get('end', 0)
+    gap = episode_duration - last_segment_end
+    if gap < TAIL_GAP_MIN_SECONDS:
+        return None
+
+    start = max(0.0, last_segment_end - TAIL_GAP_OVERLAP_BACK)
+    end = episode_duration
+
+    if _region_covered(start, end, existing_ads):
+        return None
+
+    logger.info(
+        f"Heuristic tail-gap detected: {start:.1f}s-{end:.1f}s "
+        f"(transcript ended at {last_segment_end:.1f}s, audio ends at {episode_duration:.1f}s, "
+        f"gap={gap:.1f}s)"
+    )
+
+    return {
+        'start': start,
+        'end': end,
+        'confidence': 0.85,
+        'reason': (
+            f'Tail-gap post-roll ({gap:.0f}s of untranscribed audio at end-of-file, '
+            f'likely musical/silent outro or DAI-inserted ad)'
+        ),
+        'detection_stage': 'heuristic_tail_gap',
+    }
