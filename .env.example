# Pocket Casts Ad-Free Pipeline — environment template
#
# 1. Copy:    cp .env.example .env
# 2. Fill in your Pocket Casts credentials below.
# 3. Source:  source .env  (or run `start_services.sh`, which sources it for you).
#
# Never commit your real .env file — it's already in .gitignore.

# --- Pocket Casts credentials (required) -----------------------------------
export POCKETCASTS_EMAIL='you@example.com'
export POCKETCASTS_PASSWORD='your-pocket-casts-password'

# --- Ad-detection LLM (optional overrides) ---------------------------------
# Defaults are sensible for a local Ollama install on macOS Apple Silicon.
# Pick a model that fits your machine — see README "Tuning the LLM" table.
#
#   ≥ 48 GB free RAM:   qwen3.5-addetect  (a 16K-ctx variant of qwen3.5:35b-a3b)
#   24-48 GB:           qwen3:14b         (recommended default for 36 GB Macs)
#   8-24 GB:            llama3.1:8b
#
# export OPENAI_MODEL='qwen3:14b'
# export OPENAI_BASE_URL='http://localhost:11434/v1'

# --- Ad-cut padding (optional, see patches/README.md) ----------------------
# Pre-roll / standard post-roll padding in seconds.
# export AD_START_PAD=1.5
# export AD_END_PAD=2.0
# Extra padding for ads that end at the very end of the file
# (catches musical outros that Whisper failed to transcribe).
# export AD_END_PAD_TAIL=5.0
# Minimum untranscribed-tail length (seconds) before we treat it as a post-roll.
# export TAIL_GAP_MIN_SECONDS=60

# --- MinusPod runtime tuning (optional) ------------------------------------
# export WINDOW_SIZE_SECONDS=600
# export WINDOW_OVERLAP_SECONDS=120
# export AD_DETECTION_MAX_TOKENS=4096
# Each in-flight LLM slot duplicates the KV cache. Bump only if you have
# ≥ 48 GB free RAM AND aren't running a browser/IDE.
# export OLLAMA_NUM_PARALLEL=1
# Cap how many models Ollama keeps resident. Bumping >1 silently doubles
# memory if MinusPod swaps detection ↔ verification ↔ chapters models.
# export OLLAMA_MAX_LOADED_MODELS=1
# How long Ollama keeps the model loaded after the last request (`30s` /
# `5m` / `0` to evict immediately). Short values quiet the fans between
# episodes; long values save the ~30s reload cost.
# export OLLAMA_KEEP_ALIVE=30s

# --- Pipeline safety nets (optional) ---------------------------------------
# Hard cap on a single episode in seconds. If exceeded the orchestrator
# gives up and moves to the next so the queue stays unblocked.
# export EPISODE_MAX_WALLCLOCK_SECONDS=5400
# If MinusPod's reported processing stage doesn't change for this many
# seconds, restart whisper-server (then the same threshold a second time
# aborts the episode).
# export EPISODE_STALL_THRESHOLD_SECONDS=900
